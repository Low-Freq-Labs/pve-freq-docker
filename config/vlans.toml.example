# FREQ VLAN Definitions
# Define your network VLANs here. Used by fleet operations and NIC profiles.
#
# Fields:
#   id      = VLAN ID (0 = untagged/native LAN)
#   name    = Human-readable name
#   subnet  = CIDR notation
#   prefix  = IP prefix for this VLAN
#   gateway = Default gateway (optional — omit for storage-only VLANs)

[vlan.lan]
id = 0
name = "LAN"
subnet = "192.168.1.0/24"
prefix = "192.168.1"
gateway = "192.168.1.1"

# [vlan.management]
# id = 100
# name = "MGMT"
# subnet = "10.0.100.0/24"
# prefix = "10.0.100"
# gateway = "10.0.100.1"

